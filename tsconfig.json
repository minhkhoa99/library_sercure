{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "paths": {
      "@lib-sercure/security": ["libs/security/src"],
      "@lib-sercure/security/*": ["libs/security/src/*"]
    }
  },
  "include": ["libs/**/*.ts", "test/**/*.ts", "jest.config.ts", "examples/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
